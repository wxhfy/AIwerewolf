# ============================================================================
# AI Werewolf — Environment Template
# ============================================================================
# Quick start:
#   cp .env.example .env
#   # edit .env with your API keys
#   make deploy
# ============================================================================

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# Active provider: "doubao" | "deepseek" | "fake" (no-cost smoke tests)
LLM_PROVIDER=doubao

# Primary: 火山方舟 doubao-seed-2.0-pro
DOUBAO_API_KEY=<your-doubao-api-key>
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=Doubao-Seed-2.0-pro
DOUBAO_ENDPOINT=

# Fallback: DeepSeek v4 Flash
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Game Mode
# ---------------------------------------------------------------------------
# Strict mode: raise on LLM failures instead of fallback (default: true)
AIWEREWOLF_STRICT_MODE=true
# Allow heuristic fallback for invalid targets (default: false)
ALLOW_FALLBACK=false

# ---------------------------------------------------------------------------
# Service Ports / Hosts
# ---------------------------------------------------------------------------
# Host-facing ports used by Makefile and docker-compose.
APP_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3001
NGINX_PORT=80

# PostgreSQL container port mapping.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=werewolf
POSTGRES_PASSWORD=werewolf_dev_password
POSTGRES_DB=werewolf

# Internal ports should usually stay fixed because nginx routes to container names.
BACKEND_CONTAINER_PORT=8000
FRONTEND_CONTAINER_PORT=3001

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local backend / scripts use SQLite when DATABASE_URL is unset.
# Uncomment this after `make db-up` if you want local PostgreSQL instead.
# DATABASE_URL=postgresql+psycopg2://werewolf:werewolf_dev_password@127.0.0.1:5433/werewolf

# Docker backend connects through the compose service name.
COMPOSE_DATABASE_URL=postgresql+psycopg2://werewolf:werewolf_dev_password@postgres:5432/werewolf

# ---------------------------------------------------------------------------
# Frontend (for docker-compose nginx proxy)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
