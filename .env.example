# ---------------------------------------------------------------------------
# AI Werewolf — environment template
#   1. cp .env.example .env
#   2. fill in the secrets below (DOUBAO + DEEPSEEK are project-issued)
#   3. (optional) point DATABASE_URL at your Postgres; otherwise SQLite is used
# ---------------------------------------------------------------------------

# Primary LLM: 方舟 doubao-seed 2.0 pro & code (项目组提供)
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=Doubao-Seed-2.0-pro
# Optional explicit endpoint id (ep-xxxx) when running via the Ark gateway
DOUBAO_ENDPOINT=

# Fallback: DeepSeek v4 Flash
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Active LLM provider: "doubao" | "deepseek"
LLM_PROVIDER=deepseek

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Leave blank to fall back to SQLite at data/werewolf.db (dev only).
# Local docker postgres (matches docker-compose.yml / Makefile):
DATABASE_URL=postgresql+psycopg2://werewolf:wolf_secret_2026@127.0.0.1:5433/werewolf

# Inside docker-compose, the backend reaches Postgres at host "postgres":
# DATABASE_URL=postgresql+psycopg2://werewolf:wolf_secret_2026@postgres:5432/werewolf

# Other LLM APIs (add as needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
